<UserControl x:Class="AdivinaQuienCliente.ViewModels.ConexionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AdivinaQuienCliente.Views" xmlns:viewmodels="clr-namespace:AdivinaQuienCliente.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModelCliente}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="ADIVINA QUIÉN" FontSize="28" FontWeight="Bold" 
                 HorizontalAlignment="Center" Margin="0,0,0,30" Foreground="#2C3E50"/>

            <TextBlock Text="Dirección IP del Servidor:" Margin="0,5"/>
            <TextBox  Padding="5" Margin="0,0,0,15" Text="127.0.0.1" />

            <TextBlock Text="Nombre:" Margin="0,5"/>
            <TextBox Padding="5" Margin="0,0,0,25" Text="8888"/>

            <Button
                Command="{Binding IrASalaCommand}"
                Content="CONECTARSE" 
              Background="#27AE60" Foreground="White" 
              FontWeight="Bold" Height="40"
              Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <TextBlock Text="Esperando conexión..." Margin="0,15,0,0" 
                 HorizontalAlignment="Center" Foreground="Gray" FontSize="11"/>
        </StackPanel>
    </Grid>
</UserControl>
