<UserControl x:Class="AdivinaQuienCliente.Views.TableroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AdivinaQuienCliente.Views"
             xmlns:viewmodels="clr-namespace:AdivinaQuienCliente.Views" xmlns:viewmodels1="clr-namespace:AdivinaQuienCliente.ViewModels" 
             
             mc:Ignorable="d" 
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#F4F6F7">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.65*"/>
            <ColumnDefinition Width="0.35*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="10" Background="White" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel>

                    <TextBlock Text="{Binding Turno}"
                        FontSize="18" FontWeight="DemiBold" Foreground="#2C3E50">

                    </TextBlock>
                    <TextBlock Text="Personajes" 
FontSize="18" FontWeight="Bold" Foreground="#2C3E50" 
Margin="20,15" HorizontalAlignment="Center"/>

                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ListaPersonajes}" Margin="10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="6" Rows="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="5" Padding="5" Background="Transparent" BorderThickness="0"
                    Tag="True" x:Name="btnPersonaje">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Command" Value="{Binding DataContext.VoltearCartaCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                            <Setter Property="CommandParameter" Value="{Binding RelativeSource={RelativeSource Self}}"/>

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.Modo, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="Seleccion">
                                                    <Setter Property="Command" Value="{Binding DataContext.AdivininarPersonajeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                    <Setter Property="CommandParameter" Value="{Binding Nombre}"/>
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="False">
                                                    <Setter Property="Opacity" Value="0.3"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>

                                    <Border Background="#FDFEFE" BorderBrush="#D5DBDB" BorderThickness="1" CornerRadius="5">
                                        <StackPanel>
                                            <Image Source="{Binding ImagenUrl}" Height="80" Width="80" Stretch="UniformToFill" Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding Nombre}" FontSize="11" FontWeight="SemiBold" 
                                   HorizontalAlignment="Center" Foreground="#2C3E50" Margin="0,0,0,5"/>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid  Grid.Column="1" Margin="0,10,10,10" Background="#E5E8E8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Border  CornerRadius="10,10,0,0" Padding="15">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="HISTORIAL DE CHAT" 
                           TextAlignment="Center" Foreground="#F1C40F" FontWeight="Bold" FontSize="12" Margin="0,0,0,10"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding HistorialChat}" Foreground="White">
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Grid >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="#34495E" CornerRadius="10,10,0,0" Padding="15" BorderBrush="#F1C40F" BorderThickness="0,0,0,2">
                    <StackPanel>
                        <TextBlock Text="TU PERSONAJE" HorizontalAlignment="Center" 
             Foreground="#F1C40F" FontWeight="Bold" FontSize="10" Margin="0,0,0,8"/>

                        <Border Background="#FDFEFE" CornerRadius="8" Padding="5" Width="100" HorizontalAlignment="Center">
                            <StackPanel>
                                <Image Source="{Binding PersonajeElegido.ImagenUrl}" Height="70" Width="70" Stretch="UniformToFill"/>
                                <TextBlock Text="{Binding PersonajeElegido.Nombre}" FontSize="11" FontWeight="Bold" 
                     HorizontalAlignment="Center" Foreground="#2C3E50" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="#2C3E50" Padding="10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="HISTORIAL DE CHAT" 
             TextAlignment="Center" Foreground="#BDC3C7" FontWeight="Bold" FontSize="11" Margin="0,0,0,10"/>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding HistorialChat}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="White" TextWrapping="Wrap" Margin="0,2,0,5" FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Opacity" Value="0.9"/>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Grid.Row="2" Background="#E5E8E8" Padding="10" BorderBrush="#D5DBDB" BorderThickness="0,1,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Padding="8" Margin="0,0,5,0" Text="{Binding Pregunta, UpdateSourceTrigger=PropertyChanged}"
           VerticalContentAlignment="Center" BorderThickness="1" BorderBrush="#BDC3C7"/>
                        <Button Grid.Column="1" Content="PREGUNTAR" Background="#27AE60" 
          Command="{Binding PreguntarCommand}" IsEnabled="{Binding TurnoPreguntar}"
          Foreground="White" FontWeight="Bold" Padding="15,5" Cursor="Hand"/>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Background="#E5E8E8" CornerRadius="0,0,10,10" Padding="10">
                    <StackPanel>
                  
                        <Grid HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Margin="0,0,10,0" Grid.Column="0" Content="SÍ" Background="#2ecc71" 
              Command="{Binding ResponderCommand}" CommandParameter="Si" IsEnabled="{Binding TurnoResponder}"
              Foreground="White" FontWeight="Bold" Width="60" Padding="5" Cursor="Hand"/>
                            <Button Margin="10,0,0,0" Grid.Column="1" Content="NO" Background="#E74C3C" 
              Command="{Binding ResponderCommand}" CommandParameter="No" IsEnabled="{Binding TurnoResponder}"
              Foreground="White" FontWeight="Bold" Width="60" Padding="5" Cursor="Hand"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>


            <Border Grid.Row="4"  CornerRadius="0,0,10,10" Padding="10,0,10,10">
                <Button Content="¡ADIVINAR PERSONAJE!" 
                Background="#2980B9" 
                Foreground="White" 
                FontWeight="Bold" 
                FontSize="12"
                Padding="10" 
                Cursor="Hand"
                Command="{Binding CambiarDeModoCommand}"
                    IsEnabled="{Binding PuedesAdivinar}"    >
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Border>



        </Grid>
    </Grid>
</UserControl>
