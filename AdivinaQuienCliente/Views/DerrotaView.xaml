<UserControl x:Class="AdivinaQuienCliente.Views.DerrotaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AdivinaQuienCliente.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#1A000000">
        <Border Background="White" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Center" 
            Width="350" 
            CornerRadius="15" 
            Padding="30"
            BorderBrush="#E74C3C"
            BorderThickness="0,4,0,0">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="¡FIN DEL JUEGO!" 
                       FontSize="12" 
                       FontWeight="Bold" 
                       Foreground="#E74C3C" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,5"/>

                <TextBlock Text="HAS PERDIDO" 
                       FontSize="28" 
                       FontWeight="Black" 
                       Foreground="#2C3E50" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,25"/>

                <Border Background="#FDF2F2" 
                    CornerRadius="10" 
                    Padding="20" 
                    Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="EL PERSONAJE ERA:" 
                               FontSize="10" 
                               Foreground="#95A5A6" 
                               HorizontalAlignment="Center" 
                               FontWeight="Bold"/>

                        <TextBlock Text="Nombre" 
                               FontSize="24" 
                               Foreground="#C0392B" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Center" 
                               Margin="0,10,0,0"/>

                        <TextBlock Text="👤" 
                               FontSize="50" 
                               HorizontalAlignment="Center" 
                               Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Tu oponente adivinó primero." 
                       Foreground="#7F8C8D" 
                       FontSize="13" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,25"/>

                <Button Content="VOLVER A LA SALA" 
                    Command="{Binding VolverASalaCommand}"
                    Background="#2C3E50" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    Height="45"
                    Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
