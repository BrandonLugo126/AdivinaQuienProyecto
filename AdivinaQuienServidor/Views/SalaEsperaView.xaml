<UserControl x:Class="AdivinaQuienServidor.Views.SalaEsperaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AdivinaQuienServidor.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">

            <TextBlock Text="ADIVINA QUIÉN" 
                   FontSize="28" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,10" 
                   Foreground="#2C3E50"/>

            <TextBlock Text="SALA DE ESPERA" 
                   FontSize="14" 
                   FontWeight="SemiBold"
                   Foreground="#7F8C8D"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,30"
                   />

           

            <StackPanel Margin="0,25,0,0">
                <ProgressBar IsIndeterminate="True" 
                         Height="3" 
                         Background="#D5DBDB" 
                         Foreground="#27AE60" 
                         BorderThickness="0"/>

                <TextBlock Text="Uniendose al servidor..." 
                       HorizontalAlignment="Center" 
                       Margin="0,15,0,0" 
                       FontSize="11" 
                       Foreground="Gray" 
                       FontStyle="Italic"/>
            </StackPanel>

           

        </StackPanel>
    </Grid>
</UserControl>
