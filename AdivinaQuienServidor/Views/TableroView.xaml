<UserControl x:Class="AdivinaQuienServidor.Views.TableroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AdivinaQuienServidor.Views" xmlns:viewmodels="clr-namespace:AdivinaQuienServidor.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModelServidor}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#F4F6F7">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.65*"/>
            <ColumnDefinition Width="0.35*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="10" Background="White" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Personajes" 
                       FontSize="18" FontWeight="Bold" Foreground="#2C3E50" 
                       Margin="20,15" HorizontalAlignment="Center"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ListaPersonajes}" Margin="10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="6" Rows="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="5" Padding="5" Background="Transparent" BorderThickness="0"
                    Tag="True" x:Name="btnPersonaje">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Command" Value="{Binding DataContext.VoltearCartaCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                            <Setter Property="CommandParameter" Value="{Binding RelativeSource={RelativeSource Self}}"/>

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.Modo, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="Seleccion">
                                                    <Setter Property="Command" Value="{Binding DataContext.SeleccionarPersonajeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                    <Setter Property="CommandParameter" Value="{Binding Nombre}"/>
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="False">
                                                    <Setter Property="Opacity" Value="0.3"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>

                                    <Border Background="#FDFEFE" BorderBrush="#D5DBDB" BorderThickness="1" CornerRadius="5">
                                        <StackPanel>
                                            <Image Source="{Binding ImagenUrl}" Height="80" Width="80" Stretch="UniformToFill" Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding Nombre}" FontSize="11" FontWeight="SemiBold" 
                                   HorizontalAlignment="Center" Foreground="#2C3E50" Margin="0,0,0,5"/>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="0,10,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Border Background="#2C3E50" CornerRadius="10,10,0,0" Padding="15">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="HISTORIAL DE CHAT" 
                           TextAlignment="Center" Foreground="#F1C40F" FontWeight="Bold" FontSize="12" Margin="0,0,0,10"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding HistorialChat}" Foreground="White">
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Background="#E5E8E8"  Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox  Padding="8" Margin="0,0,5,0" Text="{Binding Pregunta}"
                         VerticalContentAlignment="Center" BorderThickness="0"/>
                    <Button Grid.Column="1" Content="ENVIAR" Background="#27AE60"  Command="{Binding PreguntarCommand}" IsEnabled="{Binding TurnoPreguntar}"
                        Foreground="White" FontWeight="Bold" Padding="15,5" Cursor="Hand"/>
                </Grid>
            </Border>
            <Border Grid.Row="2" Background="#E5E8E8" CornerRadius="0,0,10,10" Padding="10">
                <Grid HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Margin="0,0,10,0"  Grid.Column="0" Content="SI" Background="#27AE60" Command="{Binding ResponderCommand}" CommandParameter="Si"
        Foreground="White" FontWeight="Bold" Padding="15,5" Cursor="Hand"/>
                    <Button Margin="10,0,0,0" Grid.Column="1" Content="NO" Background="#E74C3C"  Command="{Binding ResponderCommand}" CommandParameter="No"
                       Foreground="White" FontWeight="Bold" Padding="15,5" Cursor="Hand"/>
                </Grid>
            </Border>




        </Grid>
    </Grid>
</UserControl>
