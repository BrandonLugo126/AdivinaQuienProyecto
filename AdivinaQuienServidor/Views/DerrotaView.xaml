            Background="White" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Center" 
            Width="800"
            CornerRadius="15" 
            Padding="30">


            <StackPanel>
                <TextBlock Text="¡FIN DEL JUEGO!" 
                       FontSize="12" 
                       FontWeight="Bold" 
                       Foreground="#E74C3C" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,5"/>

                <TextBlock Text="HAS PERDIDO" 
                       FontSize="28" 
                       FontWeight="Black" 
                       Foreground="#2C3E50" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,25"/>

                <Border Background="#FDF2F2" 
                    CornerRadius="10" 
                    Padding="20" 
                    Margin="0,0,0,30">
                    <StackPanel>

                        <TextBlock Text="{Binding Mensaje}" 
                               FontSize="16" 
                               Foreground="#C0392B" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Center" 
                               Margin="0,10,0,0"/>

                      
                    </StackPanel>
                </Border>

                <TextBlock Text="Tu oponente adivinó primero." 
